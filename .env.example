# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  docker-compose.pipeline.yml 환경변수 템플릿
#
# 사용법:
#   cp .env.example .env
#   .env 파일에 실제 값을 채운 후 docker-compose 실행
#
# 주의: .env 파일은 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ─── Message Queue (RabbitMQ) ─────────────────────────────────────────────────
RABBITMQ_HOST=your_rabbitmq_host
RABBITMQ_PORT=5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password

# ─── API Server ───────────────────────────────────────────────────────────────
# 클라이언트(브라우저)에서 접근 가능한 백엔드 주소
API_BASE_URL=http://your_server_ip:8000

# ─── Queue Prefix (환경 간 메시지 혼선 방지) ──────────────────────────────────
# prod: Linux/Docker 기본값  |  dev: Windows 로컬 기본값
# 동일 RabbitMQ 브로커를 로컬+Docker가 공유할 때 반드시 분리 필요
QUEUE_PREFIX=prod

# ─── Timezone ─────────────────────────────────────────────────────────────────
TZ=Asia/Seoul
