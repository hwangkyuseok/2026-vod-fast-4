# ─────────────────────────────────────────────────────────────────────────────
# backend/.env.example  —  로컬 Python 개발 환경 설정 템플릿
#
# 사용법:
#   cp backend/.env.example backend/.env
#   backend/.env 파일에 실제 값을 채운 후 Python 실행
#
# 주의: backend/.env 파일은 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=your_db_host
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ─── Message Queue (RabbitMQ) ─────────────────────────────────────────────────
RABBITMQ_HOST=your_rabbitmq_host
RABBITMQ_PORT=5672
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password

# ─── API Server ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# ─── Queue Prefix (환경 간 메시지 혼선 방지) ──────────────────────────────────
# 로컬 Windows 환경은 "dev", Docker/Linux는 "prod" 권장
QUEUE_PREFIX=dev

# ─── 파일 경로 (Windows 예시 — 실제 경로로 변경하세요) ───────────────────────
# AD_VIDEO_DIR=D:\path\to\TV_CF\output
# AD_IMAGE_DIR=D:\path\to\TV_CF\output_print
# STORAGE_BASE=D:\path\to\2026_VOD_FAST_4\storage
# VOD_DIR=D:\path\to\2026_VOD_FAST_4\vod

# ─── 파일 경로 (Linux/Docker 예시) ───────────────────────────────────────────
# AD_VIDEO_DIR=/ads/video
# AD_IMAGE_DIR=/ads/banner
# STORAGE_BASE=/app/storage
# VOD_DIR=/vod

# ─── Pipeline Parameters (선택) ───────────────────────────────────────────────
# FRAME_EXTRACTION_FPS=1
# SCENE_CUT_THRESHOLD=30.0
# SILENCE_THRESHOLD_DB=-40.0
# MIN_SILENCE_DURATION_SEC=1.0
# WHISPER_MODEL=small
# YOLO_MODEL=yolov8l.pt

# ─── VLM Backend ──────────────────────────────────────────────────────────────
# VLM_BACKEND: "gemini" (Google Gemini API) | "qwen" (로컬 Qwen2-VL)
VLM_BACKEND=gemini

# ─── Gemini API (VLM_BACKEND=gemini 일 때 필수) ───────────────────────────────
# Google AI Studio (https://aistudio.google.com) 에서 발급
GEMINI_API_KEY=your_gemini_api_key
# 사용할 Gemini 모델명 (기본값: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview
