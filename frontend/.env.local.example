# ─────────────────────────────────────────────────────────────────────────────
# frontend/.env.local.example  —  Next.js 환경변수 템플릿
#
# 사용법:
#   cp frontend/.env.local.example frontend/.env.local
#   frontend/.env.local 파일에 실제 값을 채운 후 npm run dev 실행
#
# 주의: .env.local 파일은 .gitignore에 포함되어 있으므로 절대 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────────────────────

# ─── 로컬 개발 환경 ───────────────────────────────────────────────────────────
# Next.js 서버(API routes)에서 백엔드로 프록시할 URL
BACKEND_URL=http://localhost:8000

# ─── Docker 환경 ──────────────────────────────────────────────────────────────
# Docker Compose 내부 서비스명으로 통신 (docker-compose.yml에서 자동 설정됨)
# BACKEND_URL=http://step5-api:8000
